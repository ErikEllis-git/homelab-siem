# ── Core SIEM ─────────────────────────────────────────────────
# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=

# Your Telegram chat/user ID
TELEGRAM_CHAT_ID=

# Shared secret for the incident-responder webhook
IR_WEBHOOK_SECRET=

# Shared secret for the SOC webhook (claude-telegram)
SOC_WEBHOOK_SECRET=

# LiteLLM API key (used by incident_responder + anomaly_detector)
LITELLM_KEY=

# ── Cluster Network ───────────────────────────────────────────
# Comma-separated IPs that should never be blocked or flagged
# Include all cluster node IPs (LAN + Tailscale) and any always-trusted devices
TRUSTED_NODE_IPS=

# SSH targets for worker nodes — user@host format
WORKER1_SSH_TARGET=user@worker1
WORKER2_SSH_TARGET=user@worker2

# Worker 2 LAN IP (used by purple_team for port scan via eno1)
WORKER2_LAN_IP=

# Subnet to scan with nmap (network_scan.py)
SCAN_SUBNET=192.168.0.0/24

# Cluster node LAN IPs to port-scan (comma-separated)
CLUSTER_NODE_IPS=

# Optional: a trusted device to track LAN presence (e.g. a phone)
TRUSTED_DEVICE_IP=

# Elasticsearch host for filebeat workers (e.g. http://orchestrator-ip:9200)
ES_HOST=

# ── AI Gateway (anomaly_detector + soc_dispatch) ──────────────
# LiteLLM master key (set in ai-gateway/.env, not here)
# LITELLM_MASTER_KEY=
